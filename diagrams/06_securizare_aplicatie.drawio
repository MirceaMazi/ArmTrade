<mxfile host="65bd71144e">
    <diagram name="Securizarea Aplicației" id="security-diagram">
        <mxGraphModel dx="657" dy="536" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1600" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;b&gt;Detalii privind Securizarea Aplicației — ArmTrade&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=20;" parent="1" vertex="1">
                    <mxGeometry x="550" y="20" width="600" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec1_box" value="" style="html=1;rounded=1;arcSize=8;fillColor=#dae8fc;strokeColor=#6c8ebf;opacity=30;" parent="1" vertex="1">
                    <mxGeometry x="40" y="80" width="900" height="580" as="geometry"/>
                </mxCell>
                <mxCell id="sec1_title" value="&lt;b&gt;1. Autentificare și Autorizare&lt;/b&gt;" style="text;html=1;fontSize=16;align=left;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;arcSize=10;spacingLeft=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="100" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="jwt_icon" value="" style="html=1;shape=mxgraph.signs.security.lock_2;fillColor=#6c8ebf;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="70" y="145" width="30" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="jwt_title" value="&lt;b&gt;JWT (JSON Web Token) — HS256&lt;/b&gt;" style="text;html=1;fontSize=14;align=left;fillColor=none;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="110" y="150" width="300" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="jwt_detail" value="&lt;div style=&quot;text-align:left;&quot;&gt;&#xa;• &lt;b&gt;Algoritm:&lt;/b&gt; HMAC-SHA256 (HS256)&lt;br&gt;&#xa;• &lt;b&gt;Durată token:&lt;/b&gt; 24 ore (exp claim)&lt;br&gt;&#xa;• &lt;b&gt;Cheie secretă:&lt;/b&gt; JWT_SECRET (variabilă de mediu, obligatorie)&lt;br&gt;&#xa;• &lt;b&gt;Payload (Claims):&lt;/b&gt; sub (userID), username, exp, iat&lt;br&gt;&#xa;• &lt;b&gt;Transport:&lt;/b&gt; Header &lt;code&gt;Authorization: Bearer {token}&lt;/code&gt;&lt;br&gt;&#xa;• &lt;b&gt;Injectare automată:&lt;/b&gt; AuthInterceptor Angular pe toate cererile HTTP&lt;br&gt;&#xa;• &lt;b&gt;Stocare client:&lt;/b&gt; localStorage (token + username)&lt;br&gt;&#xa;• &lt;b&gt;Validare server:&lt;/b&gt; AuthMiddleware verifică semnătura și expirarea&lt;br&gt;&#xa;• &lt;b&gt;Erori:&lt;/b&gt; 401 Unauthorized la token lipsă/invalid/expirat&lt;br&gt;&#xa;&lt;/div&gt;" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#6c8ebf;rounded=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="205" width="430" height="285" as="geometry"/>
                </mxCell>
                <mxCell id="bcrypt_icon" value="" style="html=1;shape=mxgraph.signs.security.lock_2;fillColor=#82b366;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="530" y="145" width="30" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="bcrypt_title" value="&lt;b&gt;Hashing Parole — bcrypt&lt;/b&gt;" style="text;html=1;fontSize=14;align=left;fillColor=none;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="570" y="150" width="250" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="bcrypt_detail" value="&lt;div style=&quot;text-align:left;&quot;&gt;&#xa;• &lt;b&gt;Algoritm:&lt;/b&gt; bcrypt (golang.org/x/crypto/bcrypt)&lt;br&gt;&#xa;• &lt;b&gt;Cost factor:&lt;/b&gt; DefaultCost (10 rounds)&lt;br&gt;&#xa;• &lt;b&gt;Parola originală:&lt;/b&gt; NU se stochează niciodată&lt;br&gt;&#xa;• &lt;b&gt;Câmp JSON:&lt;/b&gt; password_hash exclus din JSON (tag: json:&quot;-&quot;)&lt;br&gt;&#xa;• &lt;b&gt;Validare la login:&lt;/b&gt; bcrypt.CompareHashAndPassword()&lt;br&gt;&#xa;• &lt;b&gt;Validare intrare:&lt;/b&gt; username: 3-50 caractere, parolă: min 6 caractere&lt;br&gt;&#xa;&lt;/div&gt;" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#82b366;rounded=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="520" y="200" width="400" height="225" as="geometry"/>
                </mxCell>
                <mxCell id="routes_title" value="&lt;b&gt;Rute Protejate (necesită JWT valid)&lt;/b&gt;" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="530" y="380" width="300" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="routes_detail" value="&lt;div style=&quot;text-align:left;&quot;&gt;&#xa;• GET /api/watchlist — Vizualizare watchlist personal&lt;br&gt;&#xa;• POST /api/watchlist — Adăugare la watchlist&lt;br&gt;&#xa;• PUT /api/watchlist/:id/portfolio — Actualizare portofoliu&lt;br&gt;&#xa;• DELETE /api/watchlist/:id — Ștergere din watchlist&lt;br&gt;&#xa;• GET /api/analyses — Analize salvate&lt;br&gt;&#xa;• POST /api/analyses — Salvare analiză&lt;br&gt;&#xa;&lt;/div&gt;" style="text;html=1;fontSize=11;align=left;fillColor=#ffffff;strokeColor=#6c8ebf;rounded=1;arcSize=8;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="520" y="450" width="380" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="sec3_box" value="" style="html=1;rounded=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;opacity=30;" parent="1" vertex="1">
                    <mxGeometry x="960" y="80" width="980" height="580" as="geometry"/>
                </mxCell>
                <mxCell id="sec3_title" value="&lt;b&gt;3. Securitate Infrastructură&lt;/b&gt;" style="text;html=1;fontSize=16;align=left;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;arcSize=10;spacingLeft=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="990" y="90" width="300" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="docker_sec" value="&lt;b&gt;Containerizare Docker&lt;/b&gt;&lt;hr&gt;&#xa;• &lt;b&gt;Multi-stage build:&lt;/b&gt; imagini minimale de producție&lt;br&gt;&#xa;• Backend: Alpine 3.20 (doar binar compilat + CA certs)&lt;br&gt;&#xa;• Frontend: Nginx Alpine (doar fișiere statice)&lt;br&gt;&#xa;• &lt;b&gt;Izolare rețea:&lt;/b&gt; containere comunică prin rețea Docker internă&lt;br&gt;&#xa;• MongoDB neexpus extern (doar backend poate accesa)&lt;br&gt;&#xa;• &lt;b&gt;Volume persistente:&lt;/b&gt; mongo-data pentru date durabile&lt;br&gt;&#xa;• &lt;b&gt;Restart policy:&lt;/b&gt; unless-stopped pentru disponibilitate" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#d6b656;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="980" y="140" width="440" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="env_sec" value="&lt;b&gt;Gestionare Secrete&lt;/b&gt;&lt;hr&gt;&#xa;• &lt;b&gt;JWT_SECRET:&lt;/b&gt; obligatoriu (panic la lipsă) — fișier .env&lt;br&gt;&#xa;• &lt;b&gt;GEMINI_API_KEY:&lt;/b&gt; opțional — degradare grațioasă fără IA&lt;br&gt;&#xa;• &lt;b&gt;MONGO_URI:&lt;/b&gt; în variabile de mediu, nu hardcodat&lt;br&gt;&#xa;• &lt;b&gt;Fișier .env:&lt;/b&gt; încărcat cu godotenv, exclus din Git&lt;br&gt;&#xa;• &lt;b&gt;Docker:&lt;/b&gt; env_file directive pentru secrete&lt;br&gt;&#xa;• &lt;b&gt;Producție:&lt;/b&gt; API URL relativ (/api) — fără expunere URL" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#d6b656;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="980" y="410" width="440" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="nginx_sec" value="&lt;b&gt;Configurare Nginx (Reverse Proxy)&lt;/b&gt;&lt;hr&gt;&#xa;• &lt;b&gt;Proxy invers:&lt;/b&gt; ascunde backend-ul de clientul direct&lt;br&gt;&#xa;• &lt;b&gt;SPA Routing:&lt;/b&gt; try_files → fallback la index.html&lt;br&gt;&#xa;• &lt;b&gt;Header-e proxy:&lt;/b&gt; X-Real-IP, X-Forwarded-For, Host&lt;br&gt;&#xa;• &lt;b&gt;WebSocket:&lt;/b&gt; Upgrade HTTP/1.1 cu header Connection&lt;br&gt;&#xa;• &lt;b&gt;Timeout:&lt;/b&gt; proxy_read_timeout 120s (WebSocket)" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#d6b656;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="1450" y="140" width="440" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="graceful_sec" value="&lt;b&gt;Oprire Grațioasă (Graceful Shutdown)&lt;/b&gt;&lt;hr&gt;&#xa;• Interceptare semnale: SIGINT, SIGTERM&lt;br&gt;&#xa;• Timeout 5 secunde pentru cereri în desfășurare&lt;br&gt;&#xa;• Închidere conexiune MongoDB cu timeout 5s&lt;br&gt;&#xa;• Logare completă a procesului de oprire" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#d6b656;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="1450" y="350" width="440" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="sec5_title" value="&lt;b&gt;5. Arhitectura de Securitate — Fluxul Cererilor&lt;/b&gt;" style="text;html=1;fontSize=16;align=left;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;arcSize=10;spacingLeft=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1440" width="400" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="flow_client" value="&lt;b&gt;Browser Client&lt;/b&gt;&lt;br&gt;Angular SPA&lt;br&gt;&lt;i&gt;localStorage: JWT&lt;/i&gt;" style="html=1;rounded=1;arcSize=15;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1510" width="150" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="flow_interceptor" value="&lt;b&gt;AuthInterceptor&lt;/b&gt;&lt;br&gt;&lt;i&gt;Injectare Bearer Token&lt;/i&gt;" style="html=1;rounded=1;arcSize=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="280" y="1510" width="170" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="flow_nginx_f" value="&lt;b&gt;Nginx&lt;/b&gt;&lt;br&gt;&lt;i&gt;Reverse Proxy&lt;br&gt;X-Real-IP&lt;/i&gt;" style="html=1;rounded=1;arcSize=15;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="520" y="1510" width="130" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="flow_cors_f" value="&lt;b&gt;CORS&lt;/b&gt;&lt;br&gt;&lt;i&gt;Middleware&lt;br&gt;Verificare Origine&lt;/i&gt;" style="html=1;rounded=1;arcSize=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="720" y="1510" width="140" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="flow_ratelimit_f" value="&lt;b&gt;Rate Limiter&lt;/b&gt;&lt;br&gt;&lt;i&gt;10 req/min/IP&lt;br&gt;(doar /armand/*)&lt;/i&gt;" style="html=1;rounded=1;arcSize=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="930" y="1510" width="150" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="flow_authmw_f" value="&lt;b&gt;JWT Auth&lt;/b&gt;&lt;br&gt;&lt;i&gt;Middleware&lt;br&gt;Verificare Semnătură&lt;/i&gt;" style="html=1;rounded=1;arcSize=15;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="1150" y="1510" width="150" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="flow_handler_f" value="&lt;b&gt;Handler API&lt;/b&gt;&lt;br&gt;&lt;i&gt;Logica de Afaceri&lt;br&gt;Validare Intrări&lt;/i&gt;" style="html=1;rounded=1;arcSize=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="1370" y="1510" width="150" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="flow_db_f" value="&lt;b&gt;MongoDB&lt;/b&gt;&lt;br&gt;&lt;i&gt;Date izolate&lt;br&gt;per utilizator&lt;/i&gt;" style="html=1;shape=cylinder3;size=8;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="1590" y="1500" width="120" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="fa1" value="HTTPS" style="html=1;endArrow=block;endFill=1;strokeWidth=2;fontSize=10;" parent="1" source="flow_client" target="flow_interceptor" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fa2" value="+ JWT" style="html=1;endArrow=block;endFill=1;strokeWidth=2;fontSize=10;" parent="1" source="flow_interceptor" target="flow_nginx_f" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fa3" value="Proxy" style="html=1;endArrow=block;endFill=1;strokeWidth=2;fontSize=10;" parent="1" source="flow_nginx_f" target="flow_cors_f" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fa4" value="" style="html=1;endArrow=block;endFill=1;strokeWidth=2;fontSize=10;" parent="1" source="flow_cors_f" target="flow_ratelimit_f" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fa5" value="" style="html=1;endArrow=block;endFill=1;strokeWidth=2;fontSize=10;" parent="1" source="flow_ratelimit_f" target="flow_authmw_f" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fa6" value="" style="html=1;endArrow=block;endFill=1;strokeWidth=2;fontSize=10;" parent="1" source="flow_authmw_f" target="flow_handler_f" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fa7" value="" style="html=1;endArrow=block;endFill=1;strokeWidth=2;fontSize=10;" parent="1" source="flow_handler_f" target="flow_db_f" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="shield_note" value="&lt;i&gt;Fiecare cerere HTTP trece prin toate straturile de securitate în ordine.&lt;br&gt;Rutele publice sar peste JWT Auth Middleware.&lt;br&gt;Rate Limiter se aplică doar pe endpoint-urile IA (/api/armand/*).&lt;/i&gt;" style="text;html=1;fontSize=12;align=center;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;arcSize=8;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="400" y="1600" width="500" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="owasp_title" value="&lt;b&gt;Mapare OWASP Top 10 — Măsuri Implementate&lt;/b&gt;" style="text;html=1;fontSize=16;align=left;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;arcSize=10;spacingLeft=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1690" width="430" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="owasp_table" value="&lt;table style=&quot;font-size:12px;border-collapse:collapse;width:100%;&quot;&gt;&lt;tbody&gt;&lt;tr style=&quot;background: rgb(248, 206, 204);&quot;&gt;&lt;th style=&quot;border: 1px solid rgb(184, 84, 80); padding: 6px; text-align: left;&quot;&gt;Risc OWASP&lt;/th&gt;&lt;th style=&quot;border: 1px solid rgb(184, 84, 80); padding: 6px; text-align: left;&quot;&gt;Măsuri de Protecție în ArmTrade&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;&lt;b&gt;A01: Broken Access Control&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;JWT AuthMiddleware, user_id din token (nu din cerere), izolare date per utilizator&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;&lt;b&gt;A02: Cryptographic Failures&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;bcrypt pentru parole, HS256 JWT, secrete în variabile de mediu, HTTPS pe extern&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;&lt;b&gt;A03: Injection&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;MongoDB driver parametrizat (fără concatenare query), JSON binding Gin&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;&lt;b&gt;A04: Insecure Design&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;Separare responsabilități (layered architecture), middleware pipeline, graceful shutdown&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;&lt;b&gt;A05: Security Misconfiguration&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;CORS strict, JWT_SECRET obligatoriu (panic), Docker multi-stage (suprafață minimă)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;&lt;b&gt;A07: Auth Failures&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;bcrypt hashing, validare parolă ≥6 char, token expirare 24h, rate limiting pe IA&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;&lt;b&gt;A08: Data Integrity&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;JWT semnătură HS256 verifică integritatea tokenului, index unic username&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;&lt;b&gt;A09: Logging &amp;amp; Monitoring&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(204, 204, 204); padding: 5px;&quot;&gt;Logare erori server (log.Printf), Gin logger middleware implicit&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#b85450;rounded=1;arcSize=8;overflow=auto;spacing=5;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1760" width="690" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="" style="group" vertex="1" connectable="0" parent="1">
                    <mxGeometry x="40" y="690" width="910" height="610" as="geometry"/>
                </mxCell>
                <mxCell id="sec2_box" value="" style="html=1;rounded=1;arcSize=8;fillColor=#d5e8d4;strokeColor=#82b366;opacity=30;" parent="3" vertex="1">
                    <mxGeometry width="910" height="610" as="geometry"/>
                </mxCell>
                <mxCell id="sec2_title" value="&lt;b&gt;2. Protecție împotriva Atacurilor Web&lt;/b&gt;" style="text;html=1;fontSize=16;align=left;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;arcSize=10;spacingLeft=10;fontStyle=1;" parent="3" vertex="1">
                    <mxGeometry x="20" y="20" width="350" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="cors_box" value="&lt;b&gt;CORS (Cross-Origin Resource Sharing)&lt;/b&gt;&lt;hr&gt;&#xa;• Origine permisă: configurabilă prin &lt;code&gt;CORS_ORIGIN&lt;/code&gt;&lt;br&gt;&#xa;• Implicit: http://localhost:4200 (dev), http://localhost (prod)&lt;br&gt;&#xa;• Metode permise: GET, POST, PUT, DELETE, OPTIONS&lt;br&gt;&#xa;• Header-e permise: Content-Type, Authorization, Accept, Origin&lt;br&gt;&#xa;• Suport credentials: activat&lt;br&gt;&#xa;• Preflight cache: 12 ore (MaxAge: 43200)" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#82b366;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="3" vertex="1">
                    <mxGeometry x="30" y="70" width="420" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="rate_box" value="&lt;b&gt;Limitare Rată (Rate Limiting)&lt;/b&gt;&lt;hr&gt;&#xa;• Aplicate pe: endpoint-uri IA (/api/armand/*)&lt;br&gt;&#xa;• Limită: &lt;b&gt;10 cereri / minut / adresă IP&lt;/b&gt;&lt;br&gt;&#xa;• Implementare: contor in-memory per IP&lt;br&gt;&#xa;• Răspuns la depășire: &lt;b&gt;429 Too Many Requests&lt;/b&gt;&lt;br&gt;&#xa;• Curățare automată: la fiecare 5 minute&lt;br&gt;&#xa;• Protecție: prevenire abuz API Gemini costisitor" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#82b366;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="3" vertex="1">
                    <mxGeometry x="480" y="70" width="400" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="input_box" value="&lt;b&gt;Validare și Sanitizare Intrări&lt;/b&gt;&lt;hr&gt;&#xa;• Username: minim 3, maxim 50 caractere&lt;br&gt;&#xa;• Parolă: minim 6 caractere&lt;br&gt;&#xa;• Ticker: validat ca non-vid, utilizat în URL-uri Yahoo&lt;br&gt;&#xa;• ObjectID: validat la conversie MongoDB&lt;br&gt;&#xa;• Parametri query: interval și range cu valori predefinite&lt;br&gt;&#xa;• JSON binding: validare structurală automată (Gin ShouldBindJSON)" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#82b366;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="3" vertex="1">
                    <mxGeometry x="30" y="350" width="400" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="ws_sec_box" value="&lt;b&gt;Securitate WebSocket&lt;/b&gt;&lt;hr&gt;&#xa;• Timeout citire: &lt;b&gt;120 secunde&lt;/b&gt;&lt;br&gt;&#xa;• Heartbeat Ping/Pong: la fiecare &lt;b&gt;30 secunde&lt;/b&gt;&lt;br&gt;&#xa;• Buffer trimitere: maxim &lt;b&gt;16 mesaje&lt;/b&gt; per client&lt;br&gt;&#xa;• Deconectare automată la timeout&lt;br&gt;&#xa;• Upgrade HTTP→WS prin Nginx cu header-e corecte&lt;br&gt;&#xa;• Reconectare automată pe client (3s delay)" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#82b366;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="3" vertex="1">
                    <mxGeometry x="480" y="350" width="400" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="" style="group" vertex="1" connectable="0" parent="1">
                    <mxGeometry x="970" y="680" width="990" height="700" as="geometry"/>
                </mxCell>
                <mxCell id="data_iso" value="&lt;b&gt;Izolare Date Utilizator&lt;/b&gt;&lt;hr&gt;&#xa;• Watchlist: filtrat obligatoriu prin &lt;b&gt;user_id&lt;/b&gt; din JWT&lt;br&gt;&#xa;• Analize: filtrate obligatoriu prin &lt;b&gt;user_id&lt;/b&gt; din JWT&lt;br&gt;&#xa;• ID-ul utilizatorului extras din token (nu din cerere)&lt;br&gt;&#xa;• &lt;b&gt;Nici un utilizator nu poate accesa datele altui utilizator&lt;/b&gt;&lt;br&gt;&#xa;• Ștergere: verificare proprietate (user_id + item_id)" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#9673a6;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="4" vertex="1">
                    <mxGeometry x="20.204081632653057" y="62.6865671641791" width="444.4897959183673" height="208.955223880597" as="geometry"/>
                </mxCell>
                <mxCell id="yahoo_sec" value="&lt;b&gt;Comunicare Yahoo Finance&lt;/b&gt;&lt;hr&gt;&#xa;• &lt;b&gt;Crumb-based auth:&lt;/b&gt; token anti-bot reînnoit automat&lt;br&gt;&#xa;• &lt;b&gt;Cookie jar:&lt;/b&gt; sesiune HTTP persistentă&lt;br&gt;&#xa;• &lt;b&gt;User-Agent:&lt;/b&gt; Mozilla/5.0 (evitare blocare)&lt;br&gt;&#xa;• &lt;b&gt;Retry pe 429:&lt;/b&gt; așteptare 2s + 1 reîncercare&lt;br&gt;&#xa;• &lt;b&gt;Retry pe 401:&lt;/b&gt; reînnoire crumb + reîncercare&lt;br&gt;&#xa;• &lt;b&gt;Cache server:&lt;/b&gt; reduce numărul de cereri externe&lt;br&gt;&#xa;  - Grafice (5d/1d): TTL 60 secunde&lt;br&gt;&#xa;  - Fundamentale/altele: TTL 5 minute" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#9673a6;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="4" vertex="1">
                    <mxGeometry x="20.204081632653057" y="334.3283582089552" width="444.4897959183673" height="302.9850746268656" as="geometry"/>
                </mxCell>
                <mxCell id="gemini_sec" value="&lt;b&gt;Comunicare Google Gemini API&lt;/b&gt;&lt;hr&gt;&#xa;• &lt;b&gt;Transport:&lt;/b&gt; HTTPS exclusiv&lt;br&gt;&#xa;• &lt;b&gt;Cheie API:&lt;/b&gt; transmisă prin query parameter (standard Google)&lt;br&gt;&#xa;• &lt;b&gt;Degradare grațioasă:&lt;/b&gt; funcții IA dezactivate fără cheie&lt;br&gt;&#xa;• &lt;b&gt;Răspuns structurat:&lt;/b&gt; responseMimeType: application/json&lt;br&gt;&#xa;• &lt;b&gt;Parsare type-safe:&lt;/b&gt; callGeminiForType[T] cu generics Go&lt;br&gt;&#xa;• &lt;b&gt;Protecție cost:&lt;/b&gt; rate limiting previne abuz" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#9673a6;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="4" vertex="1">
                    <mxGeometry x="494.99999999999994" y="62.6865671641791" width="444.4897959183673" height="240.29850746268662" as="geometry"/>
                </mxCell>
                <mxCell id="error_sec" value="&lt;b&gt;Gestionare Erori și Logare&lt;/b&gt;&lt;hr&gt;&#xa;• &lt;b&gt;Coduri HTTP standard:&lt;/b&gt;&lt;br&gt;&#xa;  - 400 Bad Request (intrare invalidă)&lt;br&gt;&#xa;  - 401 Unauthorized (token lipsă/invalid)&lt;br&gt;&#xa;  - 404 Not Found (resursă inexistentă)&lt;br&gt;&#xa;  - 409 Conflict (username duplicat)&lt;br&gt;&#xa;  - 429 Too Many Requests (rate limit)&lt;br&gt;&#xa;  - 500 Internal Server Error (erori server)&lt;br&gt;&#xa;• &lt;b&gt;Erori interne:&lt;/b&gt; NU se expun detalii tehnice clientului&lt;br&gt;&#xa;• &lt;b&gt;Logare server:&lt;/b&gt; erori logante intern (log.Printf)" style="text;html=1;fontSize=12;align=left;fillColor=#ffffff;strokeColor=#9673a6;rounded=1;arcSize=8;spacing=10;verticalAlign=top;" parent="4" vertex="1">
                    <mxGeometry x="494.99999999999994" y="334.3283582089552" width="444.4897959183673" height="334.3283582089552" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="" style="group" vertex="1" connectable="0" parent="4">
                    <mxGeometry width="989.9999999999999" height="700.0000000000001" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="" style="group" vertex="1" connectable="0" parent="5">
                    <mxGeometry width="989.9999999999999" height="700.0000000000001" as="geometry"/>
                </mxCell>
                <mxCell id="sec4_box" value="" style="html=1;rounded=1;arcSize=8;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=30;" parent="6" vertex="1">
                    <mxGeometry width="989.9999999999999" height="700.0000000000001" as="geometry"/>
                </mxCell>
                <mxCell id="sec4_title" value="&lt;b&gt;4. Protecție Date și Comunicații Externe&lt;/b&gt;" style="text;html=1;fontSize=16;align=left;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;arcSize=10;spacingLeft=10;fontStyle=1;" parent="6" vertex="1">
                    <mxGeometry x="30.30612244897959" y="10.44776119402985" width="383.87755102040813" height="36.56716417910448" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
